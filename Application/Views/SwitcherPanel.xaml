<Window x:Class="WinVDeskEssential.Views.SwitcherPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinVDeskEssential.ViewModels"
        Title="WinVDeskEssential"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="OnDragStart">

    <Border Background="#E6202020" CornerRadius="6" BorderBrush="#40FFFFFF" BorderThickness="1"
            Margin="2" Padding="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.4" Color="Black" />
        </Border.Effect>

        <ItemsControl ItemsSource="{Binding Desktops}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="{Binding PanelOrientation}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:DesktopSlotViewModel}">
                    <Border Width="100" Height="30" Margin="2" CornerRadius="4" Cursor="Hand"
                            BorderThickness="2" x:Name="ItemBorder"
                            MouseLeftButtonUp="OnItemClick" Tag="{Binding}">
                        <Border.Background>
                            <SolidColorBrush Color="#30FFFFFF" />
                        </Border.Background>

                        <TextBlock Text="{Binding Name}"
                                   Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="6"
                                   IsHitTestVisible="False" />
                    </Border>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                            <Setter TargetName="ItemBorder" Property="BorderBrush"
                                    Value="{Binding ActiveBorderBrush}" />
                            <Setter TargetName="ItemBorder" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#50FFFFFF" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                            <Setter TargetName="ItemBorder" Property="BorderBrush"
                                    Value="Transparent" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</Window>
