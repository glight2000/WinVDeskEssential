<Window x:Class="VDesk.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VDesk Settings"
        Width="600" Height="500"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="SectionTitle">
            <Setter Property="Foreground" Value="#CCFFFFFF" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,16,0,8" />
        </Style>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="#99FFFFFF" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCFFFFFF" />
            <Setter Property="Margin" Value="0,4" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="MinWidth" Value="120" />
        </Style>
    </Window.Resources>

    <TabControl Background="Transparent" BorderThickness="0" Margin="16">
        <TabControl.Resources>
            <Style TargetType="TabItem">
                <Setter Property="Foreground" Value="#99FFFFFF" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Border" Background="Transparent" Padding="12,8" CornerRadius="4,4,0,0">
                                <ContentPresenter ContentSource="Header" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#30FFFFFF" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#20FFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </TabControl.Resources>

        <!-- General Tab -->
        <TabItem Header="General">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Panel" />
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource Label}" Text="Dock Position:" />
                        <ComboBox Grid.Column="1" x:Name="DockPositionCombo"
                                  SelectedIndex="2">
                            <ComboBoxItem Content="Top" />
                            <ComboBoxItem Content="Bottom" />
                            <ComboBoxItem Content="Left" />
                            <ComboBoxItem Content="Right" />
                        </ComboBox>
                    </Grid>
                    <CheckBox x:Name="AnimationCheckbox" Content="Enable panel animation" IsChecked="True" />

                    <TextBlock Style="{StaticResource SectionTitle}" Text="Startup" />
                    <CheckBox x:Name="AutoStartCheckbox" Content="Start with Windows" />

                    <TextBlock Style="{StaticResource SectionTitle}" Text="System Hotkeys" />
                    <TextBlock Foreground="#80FFFFFF" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Override system virtual desktop hotkeys (Ctrl+Win+Arrow, etc.) so VDesk handles them instead. Requires administrator privileges." />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="OverrideHotkeysBtn" Content="Override System Hotkeys"
                                Padding="12,6" Margin="0,0,8,0"
                                Background="#FF3B82F6" Foreground="White" BorderThickness="0" />
                        <Button x:Name="RestoreHotkeysBtn" Content="Restore System Hotkeys"
                                Padding="12,6"
                                Background="#FF6B7280" Foreground="White" BorderThickness="0" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Hotkeys Tab -->
        <TabItem Header="Hotkeys">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Keyboard Shortcuts" />
                    <DataGrid x:Name="HotkeyGrid" AutoGenerateColumns="False"
                              Background="Transparent" Foreground="White"
                              BorderThickness="0" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#20FFFFFF"
                              RowBackground="Transparent" AlternatingRowBackground="#10FFFFFF"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="60" />
                            <DataGridTextColumn Header="Action" Binding="{Binding DisplayName}" IsReadOnly="True" Width="*" />
                            <DataGridTextColumn Header="Shortcut" Binding="{Binding DisplayString}" IsReadOnly="True" Width="160" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Button Content="Restore Defaults" Padding="12,6" Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Background="#FF6B7280" Foreground="White" BorderThickness="0" />
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Desktops Tab -->
        <TabItem Header="Desktops">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Desktop Configuration" />
                    <TextBlock Foreground="#80FFFFFF" FontSize="12" TextWrapping="Wrap"
                               Text="Select a desktop from the panel to configure its name, background, watermark, and border settings." />

                    <TextBlock Style="{StaticResource SectionTitle}" Text="Window Filter" />
                    <TextBlock Foreground="#80FFFFFF" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Processes and window classes in these lists will be excluded from desktop switching." />
                    <TextBlock Style="{StaticResource Label}" Text="Excluded Process Names:" Margin="0,8,0,4" />
                    <TextBox x:Name="ExcludedProcessesBox"
                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                             Background="#20FFFFFF" Foreground="White" BorderBrush="#40FFFFFF"
                             Padding="4" />
                    <TextBlock Style="{StaticResource Label}" Text="Excluded Window Classes:" Margin="0,8,0,4" />
                    <TextBox x:Name="ExcludedClassesBox"
                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                             Background="#20FFFFFF" Foreground="White" BorderBrush="#40FFFFFF"
                             Padding="4" />
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- About Tab -->
        <TabItem Header="About">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="VDesk" FontSize="28" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Multi-Monitor Independent Virtual Desktop Manager"
                           FontSize="13" Foreground="#99FFFFFF" HorizontalAlignment="Center" />
                <TextBlock Text="v1.0.0" FontSize="12" Foreground="#66FFFFFF"
                           HorizontalAlignment="Center" Margin="0,4,0,16" />
                <TextBlock Text="Windows 11 | .NET 8 | WPF"
                           FontSize="11" Foreground="#50FFFFFF" HorizontalAlignment="Center" />
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
