<Window x:Class="WinVDeskEssential.Services.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        IsHitTestVisible="False"
        ResizeMode="NoResize">
    <Grid x:Name="RootGrid">
        <!-- Border overlays -->
        <Border x:Name="TopBorder" VerticalAlignment="Top" />
        <Border x:Name="BottomBorder" VerticalAlignment="Bottom" />
        <Border x:Name="LeftBorder" HorizontalAlignment="Left" />
        <Border x:Name="RightBorder" HorizontalAlignment="Right" />

        <!-- Watermark text blocks for each corner -->
        <TextBlock x:Name="WatermarkTopLeft"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   Visibility="Collapsed" />
        <TextBlock x:Name="WatermarkTopRight"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Visibility="Collapsed" />
        <TextBlock x:Name="WatermarkBottomLeft"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                   Visibility="Collapsed" />
        <TextBlock x:Name="WatermarkBottomRight"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Visibility="Collapsed" />
    </Grid>
</Window>
