<Application x:Class="VDesk.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:VDesk"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Global dark theme styles -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FF1E1E2E" />
        <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF3B82F6" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FF2D2D3D" />
    </Application.Resources>
</Application>
